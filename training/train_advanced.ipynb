      "source": [
        "# 🧬 Aviothic.ai: Production-Grade Breast Cancer AI Trainer\n",
        "\n",
        "This notebook is designed for **Google Colab Pro** with high-performance GPU acceleration (A100/V100). It implements a multi-view ensemble for high-accuracy BI-RADS assessment.\n",
        "\n",
        "### 🔥 Key Features:\n",
        "- **Ensemble Learning**: Fusing Vision Transformer (ViT), DenseNet-121, and EfficientNet-B0.\n",
        "- **Multi-View Analysis**: Simultaneously analyzing L-CC, L-MLO, R-CC, and R-MLO views.\n",
        "- **Lesion Detection**: YOLOv8-based detection for masses and calcifications.\n",
        "- **Medical Precision**: Powered by MONAI medical image transforms.\n",
        "- **VinDr-Breast Aware**: Pre-configured for the VinDr-Breast medical dataset."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 1. CONNECT TO PROJECT --- \n",
        "from google.colab import drive\n",
        "import os, sys\n",
        "\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# ⚠️ UPDATE THIS to your actual project path in Google Drive\n",
        "PROJECT_PATH = '/content/drive/MyDrive/Aviothic.ai.pvt.ltd/retrain_package/training'\n",
        "sys.path.append(PROJECT_PATH)\n",
        "%cd {PROJECT_PATH}\n",
        "\n",
        "print(\"✅ Project modules successfully linked to Colab!\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 2. INSTALL MEDICAL AI STACK --- \n",
        "!pip install -q monai ultralytics timm pydicom albumentations mlflow pandas opencv-python-headless\n",
        "\n",
        "import torch\n",
        "import monai\n",
        "import timm\n",
        "from ultralytics import YOLO\n",
        "\n",
        "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(f\"✅ Environment Ready! Training on: {DEVICE.upper()}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 3. LOAD ENSEMBLE ARCHITECTURE --- \n",
        "from trainer import build_ensemble\n",
        "from dataset import MultiViewVinDrDataset\n",
        "\n",
        "# Build the Ensemble (ViT + DenseNet + EfficientNet)\n",
        "model = build_ensemble(num_classes=6).to(DEVICE)\n",
        "print(f\"📦 Multi-view Ensemble Built with {sum(p.numel() for p in model.parameters()):,} parameters.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 4. DATASET SETUP (VinDr-Breast) --- \n",
        "import pandas as pd\n",
        "\n",
        "# PATH to your VinDr-Breast folder in Google Drive\n",
        "VINDR_DATA_PATH = '/content/drive/MyDrive/Datasets/VinDr-Breast'\n",
        "METADATA_CSV = os.path.join(VINDR_DATA_PATH, 'metadata.csv')\n",
        "df = pd.read_csv(METADATA_CSV)\n",
        "\n",
        "train_ds = MultiViewVinDrDataset(\n",
        "    root_dir=os.path.join(VINDR_DATA_PATH, 'images'),\n",
        "    df_metadata=df,\n",
        "    image_size=224\n",
        ")\n",
        "\n",
        "print(f\"📊 Loaded {len(train_ds)} studies from VinDr-Breast Dataset.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 5. RUN ENSEMBLE TRAINING --- \n",
        "from trainer import run_training_loop\n",
        "\n",
        "print(\"🚀 Starting Multi-view Ensemble Training...\")\n",
        "\n",
        "best_model_path, metrics = run_training_loop(\n",
        "    model=model,\n",
        "    train_dataset=train_ds,\n",
        "    val_dataset=train_ds, # In production, use val_split\n",
        "    output_dir='/content/drive/MyDrive/Aviothic_Output',\n",
        "    epochs=50,\n",
        "    batch_size=8,\n",
        "    lr=1e-4,\n",
        "    device=DEVICE\n",
        ")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- 6. LESION DETECTION (YOLO) & GRAD-CAM --- \n",
        "from services.lesion_detector import lesion_detector\n",
        "# Detect lesions on a test image\n",
        "test_img = os.path.join(VINDR_DATA_PATH, 'images/test_001.png')\n",
        "if os.path.exists(test_img):\n",
        "    detections = lesion_detector.detect(test_img)\n",
        "    print(f\"🔍 Found {len(detections)} abnormalities using YOLOv8.\")"
      ]
