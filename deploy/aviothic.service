[Unit]
Description=Aviothic FastAPI service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/aviothic
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/local/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=on-failure

[Install]
WantedBy=multi-user.target
