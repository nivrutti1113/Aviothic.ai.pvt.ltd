# Aviothic AI Medical Platform - Environment Variables

# Secret key for JWT tokens - CHANGE FOR PRODUCTION
SECRET_KEY=your_production_secret_key_here_change_this

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/aviothic_db
MONGO_DB=aviothic_db

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# Device for PyTorch (cpu or cuda)
DEVICE=cpu

# Model Configuration
MODEL_PATH=./app/models/model.pt
MODEL_VERSION=v1.0.0

# Directories
STATIC_DIR=./app/static
UPLOAD_DIR=./app/static/uploads
GRADCAM_DIR=./app/static/gradcam

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001", "https://yourdomain.com"]